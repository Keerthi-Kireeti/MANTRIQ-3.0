# Required for Vercel Production Deployment
# Create a Turso database at https://turso.tech and get these values

TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Optional: Leave blank for local file-based SQLite
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
